{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    },
    "Console": {
      "LogLevel": {
        "Default": "Warning"
      }
    }
  },
  "Llm": {
    "Provider": "Foundry",
    "Endpoint": "",
    "ApiKey": "",
    "Model": "gpt-5.4-mini",
    "ContextWindow": 128000
  },
  "Collection": {
    "UpdateIntervalMs": 1000,
    "SmartIntervalMs": 10000
  },
  "Diagnostics": {
    "ThresholdsPath": "rules/thresholds.json",
    "RulesPath": "rules/rules.json"
  },
  "Rag": {
    "Enabled": true,
    "KnowledgePath": "knowledge"
  },
  "Compaction": {
    "Enabled": true,
    "MessagesThreshold": 30,
    "KeepRecentTurns": 2
  },
  "Actions": {
    "Enabled": true,
    "RequireApproval": true,
    "AllowShell": true,
    "Shell": {
      "AllowedCommands": [ "ipconfig", "systeminfo", "tasklist", "hostname", "ver", "ping", "nslookup", "driverquery", "getmac", "whoami" ]
    }
  },
  "Telemetry": {
    "EnableSensitiveData": false,
    "Otlp": {
      "Enabled": false,
      "Endpoint": "http://localhost:4317"
    }
  },
  "Ui": {
    "DecorationLevel": "Rich",
    "StreamBodyToScrollback": true,
    "CompletionEngine": "PrettyPrompt"
  },
  "Customization": {
    "CommandsPaths": [ "~/.pcagent/commands", ".pcagent/commands" ]
  }
}
