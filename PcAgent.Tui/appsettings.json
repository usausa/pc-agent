{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "Llm": {
    "Provider": "Foundry",
    "Endpoint": "",
    "ApiKey": "",
    "Model": "gpt-5.4-mini"
  },
  "Collection": {
    "UpdateIntervalMs": 1000,
    "SmartIntervalMs": 10000
  },
  "Diagnostics": {
    "ThresholdsPath": "rules/thresholds.json",
    "RulesPath": "rules/rules.json"
  },
  "Rag": {
    "Enabled": true,
    "KnowledgePath": "knowledge"
  },
  "Actions": {
    "Enabled": true,
    "RequireApproval": true,
    "AllowShell": true
  },
  "Telemetry": {
    "EnableSensitiveData": false,
    "Otlp": {
      "Enabled": false,
      "Endpoint": "http://localhost:4317"
    }
  },
  "Ui": {
    "DecorationLevel": "Rich",
    "StreamBodyToScrollback": true,
    "CompletionEngine": "PrettyPrompt"
  },
  "Customization": {
    "CommandsPaths": [ "~/.pcagent/commands", ".pcagent/commands" ]
  }
}
